                <a href="" class="setLang btn btn-primary" title="Spanish" id="es" data-lang="es" style="margin-bottom: 2px;">Español</a>@* es = SPA *@
                <a href="" class="setLang btn btn-primary" title="Tagalog (Filipino)" id="fil" data-lang="fil" style="margin-bottom: 2px;">Tagalog (Filipino)</a>@* fil = TAG *@
                <a href="" class="setLang btn btn-primary" title="Vietnamese" id="vi" data-lang="vi" style="margin-bottom: 2px;">Tiếng Việt</a>@* vi = VIE *@
