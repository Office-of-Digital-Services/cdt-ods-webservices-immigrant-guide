@{
    ViewBag.BrowserTitle = Immigration_Website.Content.Texts.MultiPage.MultiPage.header_StateAgencies;
}
@{
    ViewBag.PageTitle = Immigration_Website.Content.Texts.MultiPage.MultiPage.header_StateAgencies;
}

<script type="text/javascript">
    var defaultActiveLink = "Home";
</script>

<div class="section section-default">
    <div class="container">
        <div id="agencyListingText">
            @Html.Partial("~/Views/Shared/ImmigrantGuide/_Spinner.cshtml")
        </div>
    </div>
</div>

<script>

    processJsonData.showAgenciesList('agencyListingText', '', 'Immigration', '', 'a', constantEntityProfileLangCode);

    function toggleCollapseSwapper(thisid) {
        var x = document.getElementById(thisid).getAttribute("class");

        if (x == "ca-gov-icon-plus-fill") {
            document.getElementById(thisid).className = "ca-gov-icon-minus-fill";
        }
        else {
            document.getElementById(thisid).className = "ca-gov-icon-plus-fill";
        }
    }

</script>		

