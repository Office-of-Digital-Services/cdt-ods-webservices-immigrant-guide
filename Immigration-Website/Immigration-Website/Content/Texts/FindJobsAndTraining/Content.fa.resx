  <data name="pageFirstServicesSectionHeader" xml:space="preserve">
    <value>پیدا کردن کار و کارآموزی - خدمات</value>
    <comment>01</comment>
  </data>
  <data name="pageIntroText" xml:space="preserve">
    <value>&lt;p style="font-size: 1.2em;"&gt;California جهت کمک به مردم برای پیدا کردن کار، خدماتی را ارائه می دهد. سازمان های مبتنی بر جامعه، مدارس بزرگسالان، و کامیونیتی کالج ها از برنامه ها و خدماتی برخوردار هستند که می توانند به شما کمک کنند تا کارآموزی حرفه ای پیدا کرده و مهارتهای شغلی تان را بهبود دهید. این سازمان ها رویدادهایی مانند نمایشگاه های کار برای استخدام دارند. آنها کلاسهایی در ارتباط با کارآموزی شغلی و آموزش فنی حرفه ای تشکیل می دهند.&lt;/p&gt;</value>
    <comment>00</comment>
  </data>
