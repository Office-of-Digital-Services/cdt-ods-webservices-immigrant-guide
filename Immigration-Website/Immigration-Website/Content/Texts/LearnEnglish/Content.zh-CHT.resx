    <value>學習英語——資源</value>
    <comment>05</comment>
  </data>
  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;div class="media-body"&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="http://www.usalearns.org/" target="_blank"&gt;&lt;strong&gt;U.S.A Learns(U.S.A 學習)&lt;/strong&gt;&lt;/a&gt;
								
								
								
                                &lt;p&gt;U.S.A Learns 是一家供成人學習英語的免費網站。在該網站上您可以練習英語聽、說、讀、寫、語法、詞彙等等。&lt;/p&gt;
                            &lt;/li&gt;
                            &lt;li&gt;
                                &lt;a href="https://learner.lincs.ed.gov/" target="_blank"&gt;&lt;strong&gt;LINCS Learner Center(LINCS 學習中心)&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;LINCS Learner Center 免費提供在線資源，學習英語閱讀、數學、科學、職業技能以及其他。&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;div class="media-body"&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://www.esldirectory.com/esl-program-search/usa/california/" target="_blank"&gt;&lt;strong&gt;ESL Directory(ESL 指南)&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;ESL Directory 是一系列供人們將英語作為第二語言進行學習的計劃。您可以在上面找到所提供的課程以及所在位置。&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
        &lt;/div&gt;</value>
    <comment>06</comment>
  </data>
