  <data name="pageFirstServicesSectionHeader" xml:space="preserve">
    <value>آموختن انگلیسی - خدمات</value>
    <comment>01</comment>
  </data>
  <data name="pageIntroText" xml:space="preserve">
    <value>&lt;p style="font-size: 1.2em;"&gt;California کلاس ها و خدماتی جهت کمک به مردم برای یادگرفتن انگلیسی دارد. این کلاسها و خدمات توسط برنامه های آموزش بزرگسالان در سرتاسر ایالت ارائه می شوند. می توانید این برنامه ها را در مدارس، کامیونیتی کالج ها، کتابخانه های عمومی، و سازمان های مبتنی بر جامعه پیدا کنید. یادگیری انگلیسی می تواند برای ادامه تحصیلات و کسب دیپلم متوسطه و مدرک تحصیلی دانشگاهی به شما کمک کند.&lt;/p&gt;</value>
