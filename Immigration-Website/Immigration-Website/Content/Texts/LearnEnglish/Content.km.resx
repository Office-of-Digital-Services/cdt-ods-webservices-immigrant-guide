  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;div class="media-body"&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="http://www.usalearns.org/" target="_blank"&gt;&lt;strong&gt;គេហទំព័រ U.S.A Learns&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;U.S.A Learns គឺជា​គេហទំព័រ​ដែលឥតបង់ប្រាក់​​សម្រាប់​មនុស្ស​ពេញេវ័យ​រៀន​ភាសាអង់គ្លេស។​  នៅលើ​គេហទំព័រនេះ​ អ្នកអាច​អនុវត្ត​ការនិយាយ ការអាន​ ការ​សរសេរ ការស្តាប់ វេយ្យករណ៍​ វាក្យសព្ទ និង​ជំនាញដទៃផ្សេង​ទៀត​ផ្នែក​ភាសអង់គ្លេស​។​&lt;/p&gt;
                            &lt;/li&gt;
                            &lt;li&gt;
                                &lt;a href="https://learner.lincs.ed.gov/" target="_blank"&gt;&lt;strong&gt;មជ្ឈមណ្ឌល LINCS Learner Center &lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;មជ្ឈមណ្ឌល LINCS Learner Center ​ផ្តល់ជូន​ធនធាន​តាម​អនឡាញ​ដោយ​ឥតគិតថ្លៃ​ ដើម្បី​សិក្សា​អំណានភាសាអង់គ្លេស គណិតវិទ្យា វិទ្យាសាស្ត្រ ជំនាញការងារ និង​ជំនាញ​ដទៃ​ផ្សេងទៀត។​&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
