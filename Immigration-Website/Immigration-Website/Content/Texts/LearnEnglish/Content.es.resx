  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;div class="media-body"&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="http://www.usalearns.org/" target="_blank"&gt;&lt;strong&gt;U.S.A Learns (EE.UU. aprende)
&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;U.S.A Learns es un sitio web gratuito de aprendizaje de inglés para adultos.  En este sitio web usted puede practicar hablar, leer, escribir, escuchar, gramática, vocabulario y más en inglés.&lt;/p&gt;
                            &lt;/li&gt;
                            &lt;li&gt;
                                &lt;a href="https://learner.lincs.ed.gov/" target="_blank"&gt;&lt;strong&gt;LINCS Learner Center (Centro para estudiantes LINCS)&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;LINCS Learner Center ofrece recursos gratis en línea para aprender lectura, matemáticas, ciencias, habilidades laborales y más en inglés.&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;div class="media-body"&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://www.esldirectory.com/esl-program-search/usa/california/" target="_blank"&gt;&lt;strong&gt;ESL Directory (Directorio de ESL)&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;ESL Directory es una lista de programas para personas que aprenden inglés como segundo idioma. Le dice las clases que se ofrecen y dónde están ubicadas.&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
