  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;div class="media-body"&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="http://www.usalearns.org/" target="_blank"&gt;&lt;strong&gt;U.S.A. Learns&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;U.S.A Learns là một trang web học tiếng Anh miễn phí dành cho người lớn. Trên trang web này, quý vị có thể luyện tập các kỹ năng nghe, nói, đọc, viết, ngữ pháp, từ vựng và nhiều kiến thức khác về tiếng Anh.&lt;/p&gt;
                            &lt;/li&gt;
                            &lt;li&gt;
                                &lt;a href="https://learner.lincs.ed.gov/" target="_blank"&gt;&lt;strong&gt;LINCS Learner Center (Trung Tâm Học Tập LINCS)&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;LINCS Learner Center cung cấp các nguồn lực trực tuyến miễn phí phục vụ việc học môn đọc tiếng Anh, môn toán, khoa học, các kỹ năng làm việc và nhiều điều khác nữa.&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;div class="media-body"&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://www.esldirectory.com/esl-program-search/usa/california/" target="_blank"&gt;&lt;strong&gt;ESL Directory (Danh Bạ ESL)&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;ESL Directory là danh sách các chương trình dành cho người học tiếng Anh như một ngôn ngữ thứ hai. Trang web sẽ cho quý vị biết có những lớp học nào được cung cấp và địa điểm tổ chức.&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
        &lt;/div&gt;</value>
