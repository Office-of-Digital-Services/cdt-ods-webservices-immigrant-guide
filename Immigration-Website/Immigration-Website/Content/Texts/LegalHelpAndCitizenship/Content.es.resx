                                    &lt;a href="https://www.uscis.gov/greencard" target="_blank"&gt;&lt;strong&gt;Entérese de cómo obtener una Tarjeta verde&lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;La agencia de Servicios de Ciudadanía e Inmigración de EE.UU (U.S. Citizenship and Immigration Services) ofrece información para convertirse en residente permanente de Estados Unidos.&lt;/p&gt;
                                &lt;/li&gt;
                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/citizenship/learners/study-test" target="_blank"&gt;&lt;strong&gt;Estudio para la prueba de ciudadanía de EE.UU.&lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;La agencia de Servicios de Ciudadanía e Inmigración de EE.UU (U.S. Citizenship and Immigration Services) ofrece información para tomar las pruebas requeridas para convertirse en ciudadano naturalizado de EE.UU.&lt;/p&gt;
                                &lt;/li&gt;

                            &lt;/ul&gt;
