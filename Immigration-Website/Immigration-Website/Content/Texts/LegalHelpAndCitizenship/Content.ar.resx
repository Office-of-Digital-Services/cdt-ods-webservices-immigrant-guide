  <data name="pageAdditionalResoucesHeader" xml:space="preserve">
    <value>المواطنة والمساعدة القانونية - الموارد</value>
    <comment>05</comment>
  </data>
  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
                &lt;div class="half"&gt;
                    &lt;div class="media"&gt;
                        &lt;div class="media-body"&gt;

                            &lt;ul class="list-standout"&gt;
                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/greencard" target="_blank"&gt;&lt;strong&gt; &amp;nbsp; &amp;nbsp; &amp;nbsp; اعرف المزيد عن الحصول على البطاقة الخضراء &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;تقدم وكالة U.S. Citizenship and Immigration Services (خدمات المواطنة الأمريكية والهجرة) معلومات حيث كيف تصبح مقيمًا دائمًا في الولايات المتحدة الأمريكية.&lt;/p&gt;
                                &lt;/li&gt;
                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/citizenship/learners/study-test" target="_blank"&gt;&lt;strong&gt; &amp;nbsp; &amp;nbsp; &amp;nbsp; الدراسة لخوض اختبار الحصول على المواطنة الأمريكية &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;تقدم وكالة U.S. Citizenship and Immigration Services (خدمات المواطنة الأمريكية والهجرة) معلومات حول خوض الاختبارات المطلوبة لتصبح مواطنًا أمريكيًا حاصلاً على الجنسية.&lt;/p&gt;
                                &lt;/li&gt;

                            &lt;/ul&gt;
                        &lt;/div&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="half"&gt;
                    &lt;div class="media"&gt;

                        &lt;div class="media-body"&gt;

                            &lt;ul class="list-standout"&gt;
                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/citizenship/other-languages" target="_blank"&gt;&lt;strong&gt; &amp;nbsp; &amp;nbsp; &amp;nbsp; الأسئلة المترجمة حول المواطنة &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;تقدم وكالة U.S. Citizenship and Immigration Services (خدمات المواطنة الأمريكية والهجرة) ترجمات للأسئلة التي تُطرح خلال مقابلة الحصول على الجنسية.&lt;/p&gt;
                                &lt;/li&gt;

                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/citizenship/apply-for-citizenship/free-naturalization-information-sessions" target="_blank"&gt;&lt;strong&gt; &amp;nbsp; &amp;nbsp; &amp;nbsp; الاجتماعات الإعلامية المجانية لخدمات المواطنة الأمريكية والهجرة &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;تقدم وكالة U.S. Citizenship and Immigration Services (خدمات المواطنة الأمريكية والهجرة) اجتماعات إعلامية مجانية. وهذه الاجتماعات مفتوحة للجمهور وتشمل معلومات عن إجراء الحصول على الجنسية.&lt;/p&gt;
                                &lt;/li&gt;
                            &lt;/ul&gt;
                        &lt;/div&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;</value>
    <comment>06</comment>
