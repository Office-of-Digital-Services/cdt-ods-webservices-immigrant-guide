  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
                &lt;div class="half"&gt;
                    &lt;div class="media"&gt;
                        &lt;div class="media-body"&gt;

                            &lt;ul class="list-standout"&gt;
                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/greencard" target="_blank"&gt;&lt;strong&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; در مورد اخذ کارت سبز اطلاعات کسب کنید &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;دفتر نمایندگی خدمات تابعیت و مهاجرت آمریکا اطلاعاتی را در ارتباط با کسب سکونت دائم در آمریکا ارائه می دهد.&lt;/p&gt;
                                &lt;/li&gt;
                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/citizenship/learners/study-test" target="_blank"&gt;&lt;strong&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; مطالعه برای آزمون اخذ تابعیت آمریکا &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;دفتر نمایندگی خدمات تابعیت و مهاجرت آمریکا اطلاعاتی را در ارتباط با گذراندن آزمون های لازم برای اخذ تابعیت آمریکا ارائه می دهد.&lt;/p&gt;
                                &lt;/li&gt;

                            &lt;/ul&gt;
                        &lt;/div&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="half"&gt;
                    &lt;div class="media"&gt;

                        &lt;div class="media-body"&gt;

                            &lt;ul class="list-standout"&gt;
                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/citizenship/other-languages" target="_blank"&gt;&lt;strong&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; سؤالات ترجمه شده مربوط به تابعیت&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;دفتر نمایندگی خدمات تابعیت و مهاجرت آمریکا ترجمه سؤالاتی که طی دوره های اخذ تابعیت پرسیده می شود را ارائه می دهد.&lt;/p&gt;
                                &lt;/li&gt;

                                &lt;li&gt;
                                    &lt;a href="https://www.uscis.gov/citizenship/apply-for-citizenship/free-naturalization-information-sessions" target="_blank"&gt;&lt;strong&gt;&amp;nbsp; &amp;nbsp; جلسات رایگان اطلاعات USCIS &amp;nbsp; &amp;nbsp;&lt;/strong&gt;&lt;/a&gt;
                                    &lt;p&gt;دفتر نمایندگی خدمات تابعیت و مهاجرت آمریکا، جلسات رایگان اطلاعاتی ارائه می دهد. این جلسات برای عموم آزاد بوده و شامل اطلاعات در ارتباط با روند اخذ تابعیت می باشند.&lt;/p&gt;
                                &lt;/li&gt;
                            &lt;/ul&gt;
                        &lt;/div&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;</value>
