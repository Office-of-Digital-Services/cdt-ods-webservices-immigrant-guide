  <data name="browserTitle" xml:space="preserve">
    <value>លទ្ធភាពទទួលបានព័ត៌មាន</value>
    <comment>00</comment>
  </data>
  <data name="pageText" xml:space="preserve">
    <value>&lt;p&gt;
            គេហទំព័ររដ្ឋ California ត្រូវបានបង្កើតឡើងដោយអនុលោមទៅតាមច្បាប់រដ្ឋាភិបាលនៃរដ្ឋ California លេខ 7405​។ ផ្នែក 7405 តម្រូវឲ្យបច្ចេកវិទ្យាអេឡិចត្រូនិច និងព័ត៌មានទាំងអស់ ដែលបានផលិតឡើង ឬទិញដោយ រដ្ឋាភិបាល California គឺត្រូវតែអាចឲ្យបុគ្គលដែលមានពិការភាពប្រើប្រាស់បាន។ ពិការភាពផ្នែក​រាងកាយ​មាន​ច្រើន​ប្រភេទ​ដែលជះឥទ្ធិពលដល់ទំនាក់ទំនងរបស់អ្នកប្រើប្រាស់នៅលើគេហទំព័រ។ ការមើលមិនឃើញ ស្តាប់មិនឮ សមត្ថភាពនៃការប្រើប្រាស់ដៃមានកម្រិត និងពិការភាពផ្នែកពុទ្ធិ គឺជាឧទាហរណ៍នៃពិការភាព ដែល​ពិការភាពនីមួយៗមានមធ្យោបាយផ្សេងគ្នា​ក្នុងការទទួលបាន​ព័ត៌មាន​អេឡិចត្រូនិចយ៉ាងមានប្រសិទ្ធិភាព។ គោលបំណងរបស់យើង គឺផ្តល់ជូននូវគេហទំព័រដែលមានប្រយោជន៍ និងមានផលិតភាពសម្រាប់អ្នក​ចូល​ទៅ​ទស្សនាគេហទំព័រទាំងអស់គ្នា។ &lt;br /&gt;&lt;br /&gt;
            ភាសានេះមាននៅក្នុង Gov. Code S. 7405 គិតត្រឹមថ្ងៃ 1/1/17។ 
        &lt;/p&gt;
        &lt;h2&gt;លក្ខណៈដែលអាចទទួលបាន&lt;/h2&gt;
		
        &lt;p&gt;ខាងក្រោមនេះ អ្នកនឹងឃើញបញ្ជីមួយស្តីពីដំណោះស្រាយបច្ចេកវិទ្យា ដែលយើងបានរួមបញ្ចូលគ្នា ដើម្បីធ្វើឲ្យ​គេហទំព័ររបស់យើងកាន់តែមានភាពងាយស្រួលក្នុងស្រាវជ្រាវរកព័ត៌មាន ទាញមកបានលឿន និងងាយ​ស្រួល​ទទួលបានពត៌មាន។ &lt;/p&gt;
		
        &lt;h3&gt;រូបថត/រូបភាព៖ &lt;/h3&gt;
		
        &lt;p&gt;ប្រើប្រាស់អក្សរជាជម្រើសកំណត់ដូចជា  "ALT" និង/ឬ "TITLE" ។ កំណត់ ALT/TITLE ផ្តល់ការពិពណ៌​នាជា​លាយ​លក្ខណ៍អក្សរស្តីពីរូបភាព ដែលអាចមើល​ឃើញ​បាន​នៅលើផ្ទាំងអេក្រង់សម្រាប់អាន ហើយវាអាចមើល​ឃើញនៅ​ពេលដាក់ម៉ៅពីខាងលើរូបភាព។ ធ្វើយ៉ាងនេះក៏មានសារៈប្រយោជន៍​ដល់អ្នកដែលបានបិ​ទរូបភាពនៅ​លើប្រាវសឺ​របស់​គេដែរ ដែលក្នុងករណីនេះ ការពិពណ៌នានឹងបង្ហាញនៅចំកន្លែងដែលរូបភាពធ្លាប់ស្ថិតនៅ។ &lt;/p&gt;
		
        &lt;h2&gt;សេចក្តីណែនាំអំពីការចូលទៅកាន់ព័ត៌មានរបស់គេហទំព័រ (WCAG) 2.0 កម្រិត AA&lt;/h2&gt;
		
        &lt;p&gt;គំរូផ្ទាំងគេហទំព័តនេះអនុលោមទៅតាមគោលការណ៍ណែនាំរបស់ WCAG 2.0 AA និងលក្ខខណ្ឌវិនិច្ឆ័យលើ​ភាព​ជោគជ័យ និងការណែនាំ​ដែលបង្កើតឡើងដោយ សមាគម World Wide Web។ លក្ខខណ្ឌវិនិច្ឆ័យនេះ​ត្រូវបានរៀបចំឡើង​ក្រោមគោល​ការណ៍​ទាំងបួនដូចខាងក្រោម៖ &lt;/p&gt;
		
        &lt;h3&gt;អាចដឹងបាន៖&lt;/h3&gt;
        &lt;ul&gt;
            &lt;li&gt;ធផ្តល់ជម្រើសអត្ថបទសម្រាប់ខ្លឹមសារព័ត៌មានដែលមិនមានលក្ខណៈជាអត្ថបទ។ &lt;/li&gt;
            &lt;li&gt;ធផ្តល់ចំណងជើង និងជម្រើសផ្សេងទៀតសម្រាប់ពហុប្រព័ន្ធព័ត៌មាន។ &lt;/li&gt;
            &lt;li&gt;ធបង្កើតខ្លឹមសារព័ត៌មានដែលអាចបង្ហាញជូនតាមវិធីផ្សេងគ្នា រួមទាំងបច្ចេកវិទ្យាជំនួយ ដោយមិន​ឲ្យបាត់​បង់​អត្ថន័យ។ &lt;/li&gt;
            &lt;li&gt;ធធ្វើវាឲ្យកាន់តែមានភាពងាយស្រួលដល់អ្នកប្រើប្រាស់ក្នុងការមើល និងស្តាប់ទៅលើខ្លឹសារព័ត៌មាន។ &lt;/li&gt;
        &lt;/ul&gt;
		
        &lt;h3&gt;អាចប្រតិបត្តិបាន៖&lt;/h3&gt;
        &lt;ul&gt;
            &lt;li&gt;ធធ្វើឲ្យមុខងារទាំងអស់អាចប្រើប្រាស់បានតាមរយៈក្តារចុច។ &lt;/li&gt;
            &lt;li&gt;ធផ្តល់ពេលឲ្យអ្នកប្រើប្រាស់បានគ្រប់គ្រាន់ដើម្បីអាន និងប្រើប្រាស់ខ្លឹមសារព័ត៌មាន។ &lt;/li&gt;
            &lt;li&gt;ធហាមប្រើប្រាស់ខ្លឹមសារព័ត៌មានដែលហាមឃាត់។ &lt;/li&gt;
            &lt;li&gt;ធជួយអ្នកប្រើប្រាស់បើកចុះឡើង និងស្វែងរកខ្លឹមសារព័ត៌មាន។ &lt;/li&gt;
        &lt;/ul&gt;

        &lt;h3&gt;អាចយល់បាន៖&lt;/h3&gt;
        &lt;ul&gt;
            &lt;li&gt;ធធ្វើឲ្យអត្ថបទអាចអានបាន និងអាចយល់បាន។ &lt;/li&gt;
            &lt;li&gt;ធធ្វើឲ្យខ្លឹមសារលេចឡើង និងប្រតិបត្តិការបានតាមវិធី ដែលអាចទាយទុកមុនបាន។ &lt;/li&gt;
            &lt;li&gt;ជួយអ្នកប្រើប្រាស់ឲ្យជៀសវាងពីការប្រព្រឹត្តិកំហុស និងកែកំហុស។&lt;/li&gt;
        &lt;/ul&gt;

        &lt;h3&gt;ដែលខ្លាំងក្លា៖&lt;/h3&gt;
        &lt;ul&gt;
            &lt;li&gt;ធ្វើឲ្យភាពចុះសម្រុងគ្នាមានកម្រិតខ្ពស់ ជាមួយនឹងឧបករណ៍ប្រើប្រាស់បច្ចុប្បន្ន និងអនាគត &lt;/li&gt;
        &lt;/ul&gt;
		
		
        &lt;p&gt;ការបន្ថែមទាំងអស់នេះ បង្កើនកម្រិតនៃលទ្ធភាពទទួលបានព័ត៌មាន និងការផ្តល់អំណាចដល់អ្នកចូល​ទស្សនា​របស់​យើង ក្នុងការបង្កើតគេហទំព័រ និងឯកសារ ដែលអាចប្រើប្រាស់បានយ៉ាងពេញលេញ ដើម្បីតម្រូវចិត្តទាំង​អស់គ្នា។ &lt;/p&gt;</value>
