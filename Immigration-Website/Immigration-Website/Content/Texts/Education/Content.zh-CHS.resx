  <data name="pageAdditionalResoucesHeader" xml:space="preserve">
    <value>附加教育资源</value>
    <comment>05</comment>
  </data>
  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;!-- &lt;div class="media-left"&gt;&lt;span class="ca-gov-icon-capitol text-accent1 biggest"&gt;&lt;/span&gt;&lt;/div&gt; --&gt;
                    &lt;div class="media-body"&gt;

                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://dream.csac.ca.gov/" target="_blank"&gt;&lt;strong&gt;Clifornia Dream Act（《加州梦想法案》）&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;California Dream Act Application（《加州梦想法案》申请）允许符合条件的有证和无证的个人申请用于大学和职业培训的助学金。&lt;/p&gt;
                            &lt;/li&gt;
                            &lt;li&gt;
                                &lt;a href="http://undoc.universityofcalifornia.edu/campus-support.html" target="_blank"&gt;&lt;strong&gt;University of California 无证学生资源&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;University of California 校园职员和教员名单可以帮助无证学生找到校内外的学术、金融、法律、医疗和社会支持。&lt;/p&gt;
                            &lt;/li&gt;


                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;

                    &lt;div class="media-body"&gt;
                        &lt;h3 class="h4"&gt;社区教育&lt;/h3&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://www2.calstate.edu/attend/student-services/resources-for-undocumented-students" target="_blank"&gt;&lt;strong&gt;California State University 无证学生资源&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;加入或计划加入 California State University 校园的学生资源清单。California State University 系统致力于确保所有 California 学生都能获得学术机会，无论其公民身份如何。&lt;/p&gt;
                            &lt;/li&gt;

                            &lt;li&gt;
                                &lt;a href="http://www.icanaffordcollege.com/en-us/financialaidinfo/dreamact.aspx" target="_blank"&gt;&lt;strong&gt;CA Community College 资源&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;加入或有意加入 California Community Colleges 之一的学生的可用援助类型列表。California Community Colleges 和高等教育领导者鼓励符合 California Dream Act 资格的学生申请助学金。&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
        &lt;/div&gt;</value>
    <comment>06</comment>
