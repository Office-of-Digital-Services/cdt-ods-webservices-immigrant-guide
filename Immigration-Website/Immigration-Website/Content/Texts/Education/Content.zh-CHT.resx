  <data name="pageAdditionalResoucesHeader" xml:space="preserve">
    <value>其他教育資源</value>
    <comment>05</comment>
  </data>
  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;!-- &lt;div class="media-left"&gt;&lt;span class="ca-gov-icon-capitol text-accent1 biggest"&gt;&lt;/span&gt;&lt;/div&gt; --&gt;
                    &lt;div class="media-body"&gt;

                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://dream.csac.ca.gov/" target="_blank"&gt;&lt;strong&gt;California Dream Act&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;California Dream Act 申請使得符合條件的有證與無證學生可以申請用於大學和職業培訓的助學金。&lt;/p&gt;
                            &lt;/li&gt;
                            &lt;li&gt;
                                &lt;a href="http://undoc.universityofcalifornia.edu/campus-support.html" target="_blank"&gt;&lt;strong&gt;University of California 無證學生資源&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;University of California 可以幫助無證學生在學校內外尋找學院、資金、法律、醫護以及社會支持的校園工作人員以及教職人員名單。&lt;/p&gt;
                            &lt;/li&gt;

                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;

                    &lt;div class="media-body"&gt;
                        &lt;h3 class="h4"&gt;社區教育&lt;/h3&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://www2.calstate.edu/attend/student-services/resources-for-undocumented-students" target="_blank"&gt;&lt;strong&gt;California State University 無證學生資源&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;為就讀或準備就讀 California State University 的學生提供的資源名單。California State University 系統致力於確保全加州學生，無論是否擁有公民身份，都可享有學院教育機會。 &lt;/p&gt;
                            &lt;/li&gt;

                            &lt;li&gt;
                                &lt;a href="http://www.icanaffordcollege.com/en-us/financialaidinfo/dreamact.aspx" target="_blank"&gt;&lt;strong&gt;CA Community College 資源&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;為在加州就讀或計劃就讀其中一所 California Community College 的學生提供的資助類型名單。California Community Colleges 以及高等教育領導者鼓勵符合 California Dream Act 條件的學生申請助學金。&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
        &lt;/div&gt;</value>
    <comment>06</comment>
  </data>
