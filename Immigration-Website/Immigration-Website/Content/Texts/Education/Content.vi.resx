  <data name="pageAdditionalResoucesHeader" xml:space="preserve">
    <value>Các Nguồn Lực Giáo Dục Bổ Sung</value>
    <comment>05</comment>
  </data>
  <data name="pageAdditionalResoucesLinks" xml:space="preserve">
    <value>&lt;div class="group"&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;
                    &lt;!-- &lt;div class="media-left"&gt;&lt;span class="ca-gov-icon-capitol text-accent1 biggest"&gt;&lt;/span&gt;&lt;/div&gt; --&gt;
                    &lt;div class="media-body"&gt;

                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://dream.csac.ca.gov/" target="_blank"&gt;&lt;strong&gt;Đạo Luật Ước Mơ California&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;Việc Áp Dụng Đạo Luật Ước Mơ California cho phép những cá nhân có và không có hồ sơ đủ điều kiện nộp đơn xin trợ cấp tài chính cho đào tạo đại học cao đằng và nghề nghiệp.&lt;/p&gt;
                            &lt;/li&gt;
                            &lt;li&gt;
                                &lt;a href="http://undoc.universityofcalifornia.edu/campus-support.html" target="_blank"&gt;&lt;strong&gt;Các Nguồn Lực cho Sinh Viên Không Có Hồ Sơ của University of California&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;Danh sách các thành viên của khoa và nhân viên trường University of California có thể giúp các sinh viên không có hồ sơ tìm kiếm sự hỗ trợ xã hội, dịch vụ chăm sóc sức khỏe, pháp lý, tài chính và học tập cả trong và ngoài trường đại học.&lt;/p&gt;
                            &lt;/li&gt;


                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="half"&gt;
                &lt;div class="media"&gt;

                    &lt;div class="media-body"&gt;
                        &lt;h3 class="h4"&gt;Giáo Dục Cộng Đồng&lt;/h3&gt;
                        &lt;ul class="list-standout"&gt;
                            &lt;li&gt;
                                &lt;a href="https://www2.calstate.edu/attend/student-services/resources-for-undocumented-students" target="_blank"&gt;&lt;strong&gt;Các Nguồn Lực cho Sinh Viên Không Có Hồ Sơ của California State University&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;Danh sách các nguồn lực cho sinh viên đang theo học, hoặc lên kế hoạch theo học tại một khuôn viên của California State University. Hệ thống California State University cam kết đảm bảo có sẵn các cơ hội học tập cho tất cả học sinh sinh viên California, bất kể tình trạng công dân.&lt;/p&gt;
                            &lt;/li&gt;

                            &lt;li&gt;
                                &lt;a href="http://www.icanaffordcollege.com/en-us/financialaidinfo/dreamact.aspx" target="_blank"&gt;&lt;strong&gt;Các Nguồn Lực của CA Community College&lt;/strong&gt;&lt;/a&gt;
                                &lt;p&gt;Danh sách các loại trợ cấp có sẵn cho học sinh đang theo học, hoặc chờ theo học, một trong những California Community Colleges ở California. Các trường California Community Colleges và các nhà lãnh đạo giáo dục đại học khuyến khích học sinh đủ điều kiện tham gia Đạo Luật Ước Mơ California xin trợ cấp tài chính.&lt;/p&gt;
                            &lt;/li&gt;
                        &lt;/ul&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;
        &lt;/div&gt;</value>
    <comment>06</comment>
